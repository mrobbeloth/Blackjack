{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Blackjack (MSVC)",
      "type": "shell",
      "command": "cmd.exe",
      "args": [
        "/C",
        "build.bat"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Build Blackjack (MSVC - direct cl.exe)",
      "type": "shell",
      "command": "cmd.exe",
      "args": [
        "/C",
        "\"${env:ProgramFiles}\\Microsoft Visual Studio\\2022\\Community\\Common7\\Tools\\VsDevCmd.bat\"",
        "&&",
        "cl.exe",
        "/nologo",
        "/std:c++20",
        "/EHsc",
        "/W4",
        "/Fo:output\\",
        "/Fe:output\\blackjack.exe",
        "src\\Blackjack.cpp",
        "src\\Card.cpp",
        "src\\Deck.cpp",
        "src\\Display.cpp",
        "src\\Hand.cpp",
        "src\\GameLogic.cpp"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "List output files",
      "type": "shell",
      "command": "Get-ChildItem -Path output | Format-List",
      "group": "none",
      "problemMatcher": []
    },
        {
      "label": "Build Tests",
      "type": "shell",
      "command": "cmd.exe",
      "args": [
        "/C",
        "build.bat",
        "test"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Build Blackjack (Linux)",
      "type": "shell",
      "command": "make",
      "args": [
        "all",
        "CXXFLAGS=-std=c++20 -g -Wall -Wextra -pedantic"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Build Tests (Linux)",
      "type": "shell",
      "command": "make",
      "args": [
        "test",
        "CXXFLAGS=-std=c++20 -g -Wall -Wextra -pedantic"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": "$gcc",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
  ]
}
